{
  "name": "mcp-apps-interactive-ui",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "A worked example of building interactive in-chat UI with MCP Apps (the io.modelcontextprotocol/ui extension): a runnable server, a vanilla-JS widget, and a field guide to the gotchas.",
  "license": "MIT",
  "author": "Neil Roberts",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamneilroberts/mcp-apps-interactive-ui"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-apps",
    "claude",
    "interactive-ui",
    "llm-tools"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && node dist/index.js",
    "start:stdio": "npm run build && node dist/index.js --stdio"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.3"
  }
}
